# Brighter Living — Invite & Identity Service (Phase 3) environment

# --- Database (D1: Homebrew Postgres locally, managed Postgres in prod) ---
DATABASE_URL=postgres://localhost:5432/bl_onboarding

# --- Auth ---
# One secret signs both candidate and HR JWTs; tokens are role-discriminated.
JWT_SECRET=change-me-in-production-use-a-long-random-string
# Candidate session token lifetime.
JWT_TTL=8h

# --- HR login (D3, pulled forward from Phase 4) ---
# Single shared HR account for now (TASK 4.1 stub). bcrypt hash of the password.
HR_EMAIL=hr@brighterliving.co.uk
# bcrypt hash — generate with: node -e "console.log(require('bcryptjs').hashSync('your-password',10))"
HR_PASSWORD_HASH=
# Identity recorded in audit_log.actor as hr:{HR_USER_ID}.
HR_USER_ID=hr-admin

# --- Adapters (D2: local impls only; aws deferred to deploy) ---
STORAGE_DRIVER=local
KMS_DRIVER=local
# Where the local storage adapter writes encrypted pack blobs.
LOCAL_STORAGE_DIR=./data/packs
# 32-byte base64 master key for the local KMS adapter (dev only; prod uses cloud KMS).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
LOCAL_KMS_MASTER_KEY=

# --- Server ---
PORT=3000

# CORS allowlist (comma-separated). Only these origins may call the API.
# In prod set the real subdomains; localhost dev ports are defaulted in code.
ALLOWED_ORIGINS=https://onboarding.brighterliving.co.uk,https://hr.brighterliving.co.uk

# --- Notifications (Phase 5 — currently no-op stubs) ---
HR_NOTIFY_EMAIL=hr@brighterliving.co.uk

# Public base URL used to build magic-link URLs.
PORTAL_BASE_URL=https://onboarding.brighterliving.co.uk
